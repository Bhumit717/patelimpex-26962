# Patel Impex MCP Server — Environment Variables
# Copy this file to .env and fill in your values
# For Vercel: Add these in Project Settings → Environment Variables

# Required: API key for authenticating MCP requests from ChatGPT
# Generate a strong random key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GPT_API_KEY=your_gpt_api_key_here

# Logging level for MCP server (DEBUG, INFO, WARN, ERROR)
MCP_LOG_LEVEL=INFO

# Optional: Google Analytics credentials (already configured in firebase-init.js)
# GA_PROPERTY_ID=properties/123456789
# GA_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# GA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
